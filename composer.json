{
  "name": "rebasesoftware/omnipay-gvp",
  "type": "library",
  "description": "GVP gateway for Omnipay payment processing library",
  "homepage": "https://github.com/rebasesoftware/omnipay-gvp",
  "license": "GPL-3.0-or-later",
  "autoload": {
    "psr-4": {
      "Omnipay\\Gvp\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "OmnipayTest\\Gvp\\": "tests/"
    }
  },
  "require": {
    "php": "^7.4||^8.0",
    "ext-dom": "*",
    "ext-json": "*",
    "ext-simplexml": "*",
    "omnipay/common": "^3.1"
  },
  "require-dev": {
    "omnipay/tests": "^3|^4"
  },
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "php-http/discovery": false
    }
  }
}
